JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here
APP_PASSWORD=change_this_password
SESSION_SECRET=generate_a_long_random_secret
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
PORT=3000
DB_PATH=./database.db
RATE_LIMIT_MAX=1500
VIDEO_UPLOAD_MAX_MB=5120

# Reverse proxy / Pangolin
# En production Docker, laissez TRUST_PROXY=1 si Pangolin est devant l'app.
TRUST_PROXY=1
PUBLIC_URL=https://fachoradar.example.com
COOKIE_SECURE=auto
COOKIE_SAMESITE=Lax

# Optionnel : seulement si vous voulez partager la connexion entre sous-domaines.
# Exemple : COOKIE_DOMAIN=.example.com
COOKIE_DOMAIN=
